{
  "mcp_zones": [
    {
      "zone": "SYSTEM/PROCESS",
      "description": "Core system process management and orchestration",
      "mcps": [
        {
          "name": "Supervisor",
          "desc": "Process supervisor for agent restart and monitoring",
          "url": "http://supervisord.org/",
          "functions": [
            "Auto-restart agents/services",
            "Log process incidents"
          ],
          "module": "supervisor.conf",
          "status": "active",
          "config_template": "supervisor.conf.j2"
        },
        {
          "name": "systemd",
          "desc": "Linux system and service manager",
          "url": "https://www.freedesktop.org/wiki/Software/systemd/",
          "functions": [
            "Start/stop system services",
            "Restart on failure"
          ],
          "module": "systemd.service",
          "status": "active",
          "config_template": "systemd.service.j2"
        },
        {
          "name": "PM2",
          "desc": "Node.js process manager",
          "url": "https://pm2.keymetrics.io/",
          "functions": [
            "Manage Node.js apps",
            "Auto-restart, clustering"
          ],
          "module": "pm2.json",
          "status": "planned"
        },
        {
          "name": "Kubernetes",
          "desc": "K8s deployments, failover, self-healing",
          "url": "https://kubernetes.io/docs/concepts/workloads/controllers/replicaset/#self-healing",
          "functions": [
            "Self-healing pods",
            "Zero-downtime deployment"
          ],
          "module": "k8s_deployment.yaml",
          "status": "active"
        }
      ]
    },
    {
      "zone": "AI/AGENT",
      "description": "AI and agent management components",
      "mcps": [
        {
          "name": "LangChain",
          "desc": "Multi-LLM logic, chaining, and routing",
          "url": "https://python.langchain.com/",
          "functions": [
            "LLM orchestration",
            "Output validation"
          ],
          "module": "langchain_router.py",
          "status": "active",
          "config_template": "langchain_config.yaml.j2"
        },
        {
          "name": "LlamaIndex",
          "desc": "LLM, vector DB, document fusion",
          "url": "https://docs.llamaindex.ai/en/stable/",
          "functions": [
            "Multi-LLM, multi-DB routing"
          ],
          "module": "llamaindex.py",
          "status": "active"
        },
        {
          "name": "HuggingFace Transformers",
          "desc": "NLP, emotion/social stream analysis",
          "url": "https://huggingface.co/docs/transformers/index",
          "functions": [
            "Text classification",
            "Threat/harm detection"
          ],
          "module": "transformers_agent.py",
          "status": "optional"
        }
      ]
    },
    {
      "zone": "DATA/EVIDENCE",
      "description": "Data management and evidence handling",
      "mcps": [
        {
          "name": "Google Drive API",
          "desc": "Cloud evidence watcher/ingest",
          "url": "https://developers.google.com/drive/api/guides/upload-files",
          "functions": [
            "Watch cloud for new evidence"
          ],
          "module": "gdrive_agent.py",
          "status": "active",
          "config_template": "gdrive_config.yaml.j2"
        },
        {
          "name": "Whisper",
          "desc": "Audio/video transcription",
          "url": "https://github.com/openai/whisper",
          "functions": [
            "Speech-to-text, diarization"
          ],
          "module": "whisper_agent.py",
          "status": "active"
        },
        {
          "name": "Tesseract OCR",
          "desc": "OCR for exhibits",
          "url": "https://github.com/tesseract-ocr/tesseract",
          "functions": [
            "PDF/image OCR"
          ],
          "module": "tesseract_agent.py",
          "status": "active"
        }
      ]
    },
    {
      "zone": "COMPLIANCE/SECURITY",
      "description": "Security and compliance management",
      "mcps": [
        {
          "name": "Vault",
          "desc": "Enterprise secret management",
          "url": "https://www.vaultproject.io/docs",
          "functions": [
            "Secret storage/rotation"
          ],
          "module": "vault_agent.py",
          "status": "planned"
        },
        {
          "name": "Sentry",
          "desc": "Incident monitoring",
          "url": "https://docs.sentry.io/",
          "functions": [
            "Monitor/log errors, security"
          ],
          "module": "sentry_agent.py",
          "status": "planned"
        }
      ]
    },
    {
      "zone": "OPERATOR UX/FRONTEND",
      "description": "User interface and visualization",
      "mcps": [
        {
          "name": "Grafana",
          "desc": "Metrics/log dashboard",
          "url": "https://grafana.com/docs/grafana/latest/",
          "functions": [
            "Visualize system/agent metrics"
          ],
          "module": "frontend/grafana/",
          "status": "active"
        }
      ]
    }
  ]
}
